# Copy to .env.local (Next.js loads .env.local automatically; do not commit real values)

# Privy (https://dashboard.privy.io) — required for wallet connect in the UI
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: opBNB Testnet RPC override
NEXT_PUBLIC_OPBNB_RPC_URL=https://opbnb-testnet-rpc.bnbchain.org

NEXT_PUBLIC_WORLD_ID_APP_ID=
NEXT_PUBLIC_WORLD_ID_ACTION=register-executor

# Server-only: IDKit v4 RP signature (never expose to the browser bundle)
WORLD_ID_RP_ID=
WORLD_ID_RP_SIGNING_KEY=

# FastAPI base URL (browser → backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# x402 task publish (EIP-3009 MockUSDC → EMEscrow); same addresses as backend MOCK_USDC_ADDRESS / EM_ESCROW_ADDRESS
NEXT_PUBLIC_MOCK_USDC_ADDRESS=
NEXT_PUBLIC_EM_ESCROW_ADDRESS=

# Optional: wallet faucet mint size in µUSDC (default 1000000000 = 1000 USDC)
NEXT_PUBLIC_FAUCET_MINT_MICROS=

# Dev only: show “skip payment” when backend runs with ENVIRONMENT=development (sends X-PAYMENT-SKIP: 1)
NEXT_PUBLIC_ALLOW_X402_SKIP=
