# ─── General ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# ─── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend (FastAPI) ─────────────────────────────────────────────────────
BACKEND_PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ─── opBNB Testnet (5611) ──────────────────────────────────────────────────
OPBNB_RPC_URL=https://opbnb-testnet-rpc.bnbchain.org
EM_AGENT_PRIVATE_KEY=0x...          # EOA with EM_AGENT_ROLE on EMEscrow
DEPLOYER_PRIVATE_KEY=0x...          # For forge/ts deploy scripts
EM_AGENT_ADDRESS=0x...
TREASURY_ADDRESS=0x...

# Contract addresses (after deploy; or use .contracts.env)
MOCK_USDC_ADDRESS=0x...
EM_ESCROW_ADDRESS=0x...
EM_REPUTATION_ADDRESS=0x...
EM_ARBITRATION_ADDRESS=0x...

# ─── BSC Testnet (97) — ERC-8004 ───────────────────────────────────────────
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
ERC8004_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ─── Greenfield Testnet ────────────────────────────────────────────────────
# RPC (either name works for scripts + backend)
GREENFIELD_RPC_URL=
# GREENFIELD_RPC=https://gnfd-testnet-fullnode-tendermint-us.bnbchain.org
GREENFIELD_CHAIN_ID=5600
GREENFIELD_BUCKET=em-evidence-testnet
# Run once: cd scripts && npm run setup-greenfield-buckets
# Upload CLI: cd scripts && npm run upload-greenfield -- --file ./x.png --task-id tk_...
# When true, FastAPI task submit (multipart file) shells out to upload-greenfield.ts
USE_GREENFIELD_UPLOAD=false

# ─── Gemini (verification L2) ──────────────────────────────────────────────
GEMINI_API_KEY=

# ─── World ID ──────────────────────────────────────────────────────────────
# Must match frontend: frontend/.env → NEXT_PUBLIC_WORLD_ID_APP_ID / NEXT_PUBLIC_WORLD_ID_ACTION
WORLD_ID_APP_ID=
WORLD_ID_ACTION=register-executor

# ─── x402 facilitator ────────────────────────────────────────────────────
X402_FACILITATOR_URL=http://localhost:8402
X402_RESOURCE_NAME=execution-market

# ─── IRC (Phase 6) ─────────────────────────────────────────────────────────
IRC_EAST_HOST=localhost
IRC_EAST_PORT=6667
IRC_NICK_SERV_PASS=

# ─── Optional: block explorer API keys ─────────────────────────────────────
OPBNB_API_KEY=
BSC_API_KEY=
