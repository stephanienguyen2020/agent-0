# ─── General ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# ─── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend (FastAPI) ─────────────────────────────────────────────────────
BACKEND_PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ─── opBNB Testnet (5611) ──────────────────────────────────────────────────
OPBNB_RPC_URL=https://opbnb-testnet-rpc.bnbchain.org
EM_AGENT_PRIVATE_KEY=0x...          # EOA with EM_AGENT_ROLE on EMEscrow
DEPLOYER_PRIVATE_KEY=0x...          # For forge/ts deploy scripts
EM_AGENT_ADDRESS=0x...
TREASURY_ADDRESS=0x...

# Contract addresses (after deploy; or use .contracts.env)
MOCK_USDC_ADDRESS=0x...
EM_ESCROW_ADDRESS=0x...
EM_REPUTATION_ADDRESS=0x...
EM_ARBITRATION_ADDRESS=0x...

# ─── BSC Testnet (97) — ERC-8004 ───────────────────────────────────────────
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
ERC8004_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ─── Greenfield Testnet ────────────────────────────────────────────────────
# RPC (either name works for scripts + backend)
GREENFIELD_RPC_URL=
# GREENFIELD_RPC=https://gnfd-testnet-fullnode-tendermint-us.bnbchain.org
GREENFIELD_CHAIN_ID=5600
GREENFIELD_BUCKET=em-evidence-testnet
# Run once: cd scripts && npm run setup-greenfield-buckets
# Upload CLI: cd scripts && npm run upload-greenfield -- --file ./x.png --task-id tk_...
# When true, FastAPI task submit (multipart file) shells out to upload-greenfield.ts
USE_GREENFIELD_UPLOAD=false

# ─── Gemini (verification L2) ──────────────────────────────────────────────
GEMINI_API_KEY=

# ─── World ID ──────────────────────────────────────────────────────────────
# Must match frontend: NEXT_PUBLIC_WORLD_ID_APP_ID / NEXT_PUBLIC_WORLD_ID_ACTION
# v4 IDKit: WORLD_ID_RP_ID (rp_...) must be set here (or backend/.env) for FastAPI — same value as frontend/.env
# so POST /api/v1/world-id/verify forwards full IDKit results to /api/v4/verify. Next.js uses WORLD_ID_RP_SIGNING_KEY (frontend/.env.local) for /api/world-id/rp-context only.
WORLD_ID_APP_ID=
WORLD_ID_RP_ID=
WORLD_ID_ACTION=register-executor
# Bounty at or above this (µUSDC, 6 decimals) requires executor Orb verification
WORLD_ID_ORB_BOUNTY_THRESHOLD_MICROS=5000000
# Set false only for local demos without World ID
WORLD_ID_ACCEPT_ENFORCE=true

# ─── x402 (EIP-3009 + facilitator) ───────────────────────────────────────
# Backend: when X402_ENFORCE=true, POST /api/v1/tasks requires X-PAYMENT (base64 JSON).
# In development, X-PAYMENT-SKIP: 1 skips payment (still uses legacy publishTask).
# Run the facilitator locally: docker compose up facilitator (repo root; needs MOCK_USDC_ADDRESS, EM_ESCROW_ADDRESS, FACILITATOR_PRIVATE_KEY in this file).
X402_ENFORCE=false
X402_FACILITATOR_URL=http://localhost:8402
X402_RESOURCE_NAME=execution-market
# Facilitator service only (see facilitator/): EOA funded with tBNB for gas; settles MockUSDC.transferWithAuthorization.
# The facilitator app loads this from the repo root .env automatically (python-dotenv); restart uvicorn/Docker after changes.
FACILITATOR_PRIVATE_KEY=0x...
# Optional: match facilitator app (defaults MockUSDC / 1)
# MOCK_USDC_EIP712_NAME=MockUSDC
# MOCK_USDC_EIP712_VERSION=1

# ─── IRC (Phase 6) ─────────────────────────────────────────────────────────
IRC_EAST_HOST=localhost
IRC_EAST_PORT=6667
IRC_NICK_SERV_PASS=

# ─── Optional: block explorer API keys ─────────────────────────────────────
OPBNB_API_KEY=
BSC_API_KEY=
